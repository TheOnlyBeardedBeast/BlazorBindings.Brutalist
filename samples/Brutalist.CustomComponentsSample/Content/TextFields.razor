@page "/textfields"
@using Brutalist.Material.Typography
@using MaterialColorUtilities.Schemes
@using BlazorBindings.Brutalist.Material.Input


<MaterialText Shrink="0" FontSize="MaterialFontSize.HeadlineMedium" Color="@CurrentTheme.OnBackground.ToHexColor()"
              TextAlign="left">
    Text Field
</MaterialText>


<BrutalistCard BorderRadius="12" Padding="16" Gap="12">
    <TextField Label="Name" Placeholder="Enter your name" ValueChanged="@OnNameInput" />
    <MaterialText Color="@CurrentTheme?.OnBackground.ToHexColor()">Name Value: @name</MaterialText>
    <TextField Label="Email" Placeholder="Enter your email" />
    <TextField Label="Message" Placeholder="Enter your message" />
    <TextField Label="Password" Placeholder="Enter your password" ValueChanged="@OnPasswordInput" IsPassword />
    <MaterialText Color="@CurrentTheme?.OnBackground.ToHexColor()">Password Value: @password</MaterialText>
</BrutalistCard>
@code {
    [CascadingParameter]
    public Scheme<uint>? CurrentTheme { get; set; }
    private string name = "";
    private void OnNameInput(string value)
    {
        name = value;
    }

    private string password = "";
    private void OnPasswordInput(string value)
    {
        password = value;
    }
}