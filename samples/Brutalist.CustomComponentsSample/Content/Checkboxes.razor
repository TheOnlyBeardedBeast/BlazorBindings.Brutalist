@using Brutalist.Material.Typography
@using MaterialColorUtilities.Schemes
@page "/checkboxes"

<MaterialText Shrink="0" FontSize="MaterialFontSize.HeadlineSmall" Color="@CurrentTheme.OnBackground.ToHexColor()"
              TextAlign="left">
    Checkboxes
</MaterialText>

<BrutalistCard BorderRadius="12" Padding="16" Gap="12">
    <MaterialText FontSize="MaterialFontSize.BodyMedium" Color="@CurrentTheme.OnBackground.ToHexColor()"
                  TextAlign="left">
        Checkbox
    </MaterialText>
    <MaterialText FontSize="MaterialFontSize.BodySmall" Color="@CurrentTheme.OnSurfaceVariant.ToHexColor()"
                  TextAlign="left">
        Base checkbox with label, two-way binding, tone, and disabled state.
    </MaterialText>
    <YogaView Direction="Yoga.YGFlexDirection.YGFlexDirectionColumn" Gap="10" AlignItems="flex-start">
        <Checkbox Label="Accept terms" @bind-Checked="AcceptedTerms" />
        <Checkbox Label="Enable analytics" Tone="Secondary" @bind-Checked="EnableAnalytics" />
        <Checkbox Label="Disabled checked" Checked="true" Disabled="true" />
        <Checkbox Label="Disabled unchecked" Checked="false" Disabled="true" />
    </YogaView>
    <MaterialText FontSize="MaterialFontSize.BodySmall" Color="@CurrentTheme.OnSurfaceVariant.ToHexColor()"
                  TextAlign="left">
        AcceptedTerms: @AcceptedTerms · EnableAnalytics: @EnableAnalytics
    </MaterialText>
</BrutalistCard>

@code {
    [CascadingParameter]
    public Scheme<uint> CurrentTheme { get; set; }
    private bool AcceptedTerms;
    private bool EnableAnalytics = true;
}