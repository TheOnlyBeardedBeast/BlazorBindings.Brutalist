@page "/size-change-example"
@using BlazorBindings.Core
@using Brutalist.Material.Typography
@using MaterialColorUtilities.Schemes
@implements IDisposable

<YogaView Direction="Yoga.YGFlexDirection.YGFlexDirectionColumn" Gap="16" Padding="16">
    <MaterialText FontSize="MaterialFontSize.HeadlineSmall">Element OnSizeChange Example</MaterialText>

    <MaterialText WrapText="true">This demo shows OnSizeChange in action. Click the button to toggle the width of the
        box below. The size changes are logged and displayed.</MaterialText>

        <Button Label="Toggle Width" OnClick="ToggleWidth" />

        <YogaView Background="#f0f0f0" BorderRadius="8" BorderWidth="1" BorderColor="#ccc" Width="@_boxWidth" Height="100f"
                  OnSizeChange="OnSizeChanged">
            <MaterialText Text="@_sizeText" CenterText="true" Color="@CurrentTheme?.OnBackground.ToHexColor()" />
        </YogaView>

        <MaterialText Color="@CurrentTheme?.OnBackground.ToHexColor()" FontSize="MaterialFontSize.TitleMedium">Size Change
            Log:</MaterialText>
            <MaterialText Color="@CurrentTheme?.OnBackground.ToHexColor()" WrapText="true">@_logText</MaterialText>
        </YogaView>

@code {
    [CascadingParameter]
    public Scheme<uint>? CurrentTheme { get; set; }

    private float _boxWidth = 200;
    private string _sizeText = "Size: ?";
    private string _logText = "";
    private ElementSizeChangedEventArgs? _latestSizeArgs;

    private readonly Throttler _sizeTextThrottler = RateLimit.Throttle(TimeSpan.FromMilliseconds(120));
    private readonly Debouncer _logDebouncer = RateLimit.Debounce(TimeSpan.FromMilliseconds(180));

    private void ToggleWidth()
    {
        _boxWidth = _boxWidth == 200 ? 300 : 200;
        StateHasChanged();
    }

    private Task OnSizeChanged(ElementSizeChangedEventArgs args)
    {
        _latestSizeArgs = args;

        _ = _sizeTextThrottler.ExecuteAsync(() =>
            InvokeAsync(() =>
            {
                if (_latestSizeArgs is null)
                {
                    return;
                }

                _sizeText = $"Size: {_latestSizeArgs.NewRect.Width}x{_latestSizeArgs.NewRect.Height}";
                StateHasChanged();
            }));

        _ = _logDebouncer.ExecuteAsync(() =>
            InvokeAsync(() =>
            {
                if (_latestSizeArgs is null)
                {
                    return;
                }

                _logText += $"Changed: {_latestSizeArgs.OldRect.Width}x{_latestSizeArgs.OldRect.Height} -> {_latestSizeArgs.NewRect.Width}x{_latestSizeArgs.NewRect.Height}\n";
                StateHasChanged();
            }));

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _sizeTextThrottler.Dispose();
        _logDebouncer.Dispose();
    }
}